<Window x:Class="NetworkAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NetworkAnalyzer"
        mc:Ignorable="d"
        Title="Network Analyzer" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Network Interfaces" Grid.Column="0" Margin="0,0,12,0">
            <DockPanel>
                <TextBox DockPanel.Dock="Top" Margin="0,0,0,8"
                         Text="{Binding InterfaceFilter, UpdateSourceTrigger=PropertyChanged}"/>
                <ListBox ItemsSource="{Binding InterfacesView}" SelectedItem="{Binding SelectedInterface}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Description}" FontSize="12" Foreground="Gray"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </GroupBox>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <GroupBox Header="Selected Interface Info" Grid.Row="0" Margin="0,0,0,12">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedInterface.Name}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Description:"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedInterface.Description}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="IP Address:"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedInterface.IpAddress}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Subnet Mask:"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedInterface.SubnetMask}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="MAC Address:"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedInterface.MacAddress}"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Status:"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedInterface.Status}"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Speed / Type:"/>
                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedInterface.SpeedAndType}"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="URL / URI Analysis" Grid.Row="1" Margin="0,0,0,12">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="URL:" VerticalAlignment="Center"/>
                    <TextBox x:Name="UrlInput" Grid.Row="0" Grid.Column="1" Margin="8,0" MinWidth="300"
                             ToolTip="{Binding UrlValidationMessage}">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUrlValid}" Value="False">
                                        <Setter Property="BorderBrush" Value="Crimson"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                        <Button Content="Parse" Width="90" Margin="0,0,8,0" Click="ParseUrl_Click"/>
                        <Button Content="Ping" Width="90" Margin="0,0,8,0" Click="Ping_Click"/>
                        <Button Content="DNS" Width="90" Click="Dns_Click"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Scheme:"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UrlScheme}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Host:"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UrlHost}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Port:"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding UrlPort}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Path:"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding UrlPath}"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Query:"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding UrlQuery}"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Fragment:"/>
                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding UrlFragment}"/>
                </Grid>
            </GroupBox>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <GroupBox Header="Results" Grid.Column="0" Margin="0,0,12,0">
                    <DockPanel>
                        <Button DockPanel.Dock="Top" Content="Clear Results" Margin="0,0,0,8"
                                Click="ClearResults_Click"/>
                        <ListBox ItemsSource="{Binding OutputLines}"/>
                    </DockPanel>
                </GroupBox>

                <GroupBox Header="URL History" Grid.Column="1">
                    <DockPanel>
                        <Button DockPanel.Dock="Top" Content="Clear History" Margin="0,0,0,8"
                                Click="ClearHistory_Click"/>
                        <ListBox ItemsSource="{Binding UrlHistory}" SelectionChanged="History_SelectionChanged"/>
                    </DockPanel>
                </GroupBox>
            </Grid>
        </Grid>
    </Grid>
</Window>
